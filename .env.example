# 邮件推送配置（可选功能，用到 HTML 研报邮件时才需要）
# 复制为 .env 并填入你的 SMTP 配置：cp .env.example .env

# SMTP 服务器与端口（QQ:smtp.qq.com/465  Gmail:smtp.gmail.com/465  163:smtp.163.com/465  Outlook:smtp.office365.com/587）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=465

# 发件邮箱与授权码（注意：多数邮箱用「授权码」而非登录密码）
SENDER_EMAIL=your_email@qq.com
SENDER_AUTH_CODE=your_smtp_auth_code

# 默认收件人，多个用英文逗号分隔
DEFAULT_RECIPIENTS=you@example.com

# 可选：融资打新利率与计息天数（覆盖 6D 模型 D6 默认值 4.5% / 7 天）
# MARGIN_ANNUAL_RATE=4.5
# MARGIN_DAYS=7
